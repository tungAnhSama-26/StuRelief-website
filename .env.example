# =========================================================================
# STURELIEF - TEMPLATE CẤU HÌNH MÔI TRƯỜNG (ENVIRONMENT VARIABLES)
# Sao chép tệp này thành .env ở thư mục thích hợp (ví dụ: thư mục /web)
# =========================================================================

# 1. CƠ SỞ DỮ LIỆU (DATABASE CONNECTION)
# Đường dẫn kết nối trực tiếp đến PostgreSQL database của hệ thống.
# Định dạng: postgresql://[username]:[password]@[host]:[port]/[database_name]
# - Do cổng 5432 mặc định thường bị trùng, hệ thống đã cấu hình chạy trên cổng 5433.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/sturelief"

# 2. ĐỊNH CẤU HÌNH ỨNG DỤNG (APP CONFIGURATION)
# Cấu hình môi trường chạy ứng dụng: "development" (phát triển) hoặc "production" (vận hành thực tế).
NODE_ENV="development"

# Địa chỉ URL của Frontend Web (Next.js) để xử lý định tuyến và CORS API.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Địa chỉ URL của Backend API (dùng khi deploy tách biệt, mặc định chạy chung với Next.js).
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# 3. BẢO MẬT & XÁC THỰC (SECURITY & AUTHENTICATION)
# Khóa bí mật dùng để mã hóa và ký mã xác thực JWT (JSON Web Token) cho phiên đăng nhập của sinh viên.
# Trong môi trường thực tế (production), hãy thay đổi chuỗi này thành một chuỗi cực kỳ bảo mật và ngẫu nhiên.
JWT_SECRET="your_super_secret_key_123_sturelief_platform"
JWT_EXPIRES_IN="7d" # Thời hạn hiệu lực của phiên đăng nhập (ví dụ: 7 ngày)

# 4. HỆ THỐNG LƯU TRỮ TỆP TIN (FILE STORAGE - Ví dụ: Upload ảnh sản phẩm)
# Cấu hình lưu trữ cục bộ (local) hoặc các dịch vụ đám mây Cloud như AWS S3 / Cloudinary.
STORAGE_PROVIDER="local" # Lựa chọn: "local" | "s3" | "cloudinary"
UPLOAD_LIMIT_MB="10"     # Giới hạn dung lượng tải lên tối đa cho mỗi ảnh (Megabytes)
